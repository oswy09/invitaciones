# Sin prefijo VITE_ a proposito: estas variables las lee unicamente
# server/index.js (proceso de Node), nunca el bundle del navegador.
# ADVERTENCIA: la service_role key tiene acceso total a la base de datos,
# sin pasar por RLS. El servidor ahora exige login (Supabase Auth) antes
# de usarla, pero sigue siendo buena practica correr esto solo en redes
# de confianza.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

VITE_ADMIN_SERVER_URL=http://localhost:3301

# Estas SI llevan prefijo VITE_ a proposito: son publicas (anon key), las
# usa el navegador unicamente para el login (Supabase Auth).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
