# Sin prefijo VITE_ a proposito: estas variables las lee unicamente
# server/index.js (proceso de Node), nunca el bundle del navegador.
# ADVERTENCIA: la service_role key tiene acceso total a la base de datos,
# sin pasar por RLS. Este dashboard debe correr SOLO en localhost mientras
# no tenga su propio login. Nunca publicar esta clave en un repo publico
# ni desplegar este proyecto en un dominio accesible sin autenticacion real.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

VITE_ADMIN_SERVER_URL=http://localhost:3301
