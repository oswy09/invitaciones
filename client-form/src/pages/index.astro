---
import Base from '../layouts/Base.astro';
import DiferenciadorSection from '../components/DiferenciadorSection.astro';
import TestimoniosSection from '../components/TestimoniosSection.astro';
import FAQSection from '../components/FAQSection';
import { CATALOGO } from '../types';

const WHATSAPP_CONTACTO = "573057502790";
const WHATSAPP_MENSAJE   = encodeURIComponent("¡Hola! Quiero saber más sobre las invitaciones digitales de Celebrarte.");
const WHATSAPP_CTA       = encodeURIComponent("Hola, quiero crear mi invitación digital con Celebrarte");

// TODO: reemplazar +XX y X.X con valores reales
const CREDIBILIDAD = "+50 celebraciones · ⭐ 4.8 en Google · 📲 Link listo en menos de 24 h";

const PASOS = [
  { num: "01", titulo: "Elige tu plantilla",  desc: "Explora nuestras invitaciones y elige la que mejor se adapte a tu celebración." },
  { num: "02", titulo: "Personalizala",        desc: "Agrega el nombre, fecha, lugar y un mensaje especial. Previsualiza en tiempo real." },
  { num: "03", titulo: "Compártela",           desc: "Recibe el enlace listo para enviar por WhatsApp, Instagram o donde quieras." },
];

const GOLD_TEXT = "#7A5C10";
---

<Base
  title="Celebrarte · Invitaciones Digitales para Baby Shower, Bodas y Cumpleaños"
  description="Crea y personaliza invitaciones digitales únicas para baby showers, bodas y cumpleaños. Listas para compartir por WhatsApp en segundos. Diseños elegantes y cálidos."
  canonical="https://celebrarte.com.co/"
>
  <slot name="head" slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Celebrarte",
      "description": "Diseño de invitaciones digitales para baby showers, bodas y cumpleaños, listas para compartir por WhatsApp.",
      "url": "https://celebrarte.com.co",
      "logo": "https://res.cloudinary.com/ddqbnr9vo/image/upload/v1783378436/logo-celebrarte_bxkmva.png",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+57-305-750-2790",
        "contactType": "customer service",
        "availableLanguage": "Spanish"
      },
      "areaServed": "CO",
      "serviceType": ["Invitaciones digitales", "Baby shower", "Bodas", "Cumpleaños"]
    }
    </script>
  </slot>

  <div class="min-h-screen" style="background-color: #F8F5F0; color: #2B2B2B; font-family: 'Poppins', sans-serif;">

    <!-- 1. NAV -->
    <header class="sticky top-0 z-50 w-full" style="background-color: white; border-bottom: 1px solid #F0E0E8; box-shadow: 0 1px 4px rgba(90,27,94,0.07);">
    <nav
      aria-label="Navegación principal"
      class="flex items-center justify-between px-6 py-4 max-w-5xl mx-auto"
    >
      <img
        src="https://res.cloudinary.com/ddqbnr9vo/image/upload/v1783378436/logo-celebrarte_bxkmva.png"
        alt="Celebrarte"
        class="h-8 w-auto"
      />
      <a
        href="/plantillas"
        class="text-sm font-semibold px-4 py-2 rounded-full transition-all"
        style="background-color: #5A1B5E; color: #F8F5F0;"
      >
        Ver plantillas
      </a>
    </nav>
    </header>

    <main>

      <!-- 2. HERO -->
      <section aria-label="Propuesta de valor" class="text-center px-6 pt-16 pb-20 max-w-3xl mx-auto">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style={`color: ${GOLD_TEXT};`}>
          Invitaciones digitales
        </p>
        <h1
          class="text-4xl md:text-5xl font-bold leading-tight mb-6"
          style="font-family: 'Playfair Display', serif; color: #5A1B5E;"
        >
          Tu celebración merece una primera impresión memorable
        </h1>
        <p class="text-base md:text-lg leading-relaxed mb-10" style="color: #4A4A4A;">
          Diseñamos invitaciones digitales animadas para baby showers, bodas y cumpleaños,
          listas para compartir por WhatsApp en segundos.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-6">
          <a
            href="/plantillas"
            class="w-full sm:w-auto text-base font-semibold px-8 py-3.5 rounded-full transition-all shadow-lg text-center"
            style="background-color: #5A1B5E; color: #F8F5F0;"
          >
            Explorar plantillas
          </a>
          <a
            href={`https://wa.me/${WHATSAPP_CONTACTO}?text=${WHATSAPP_MENSAJE}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-auto text-base font-semibold px-8 py-3.5 rounded-full border-2 transition-all text-center"
            style="border-color: #5A1B5E; color: #5A1B5E;"
          >
            Preguntar por WhatsApp
          </a>
        </div>

        <!-- Barra de credibilidad -->
        <p class="text-xs font-medium" style="color: #8B5AA0;">
          🎉&nbsp; {CREDIBILIDAD}
        </p>
      </section>

      <!-- 3. DIFERENCIADOR -->
      <DiferenciadorSection />

      <!-- 4. PLANTILLAS PREVIEW -->
      <section aria-label="Nuestras plantillas" class="px-6 py-20" style="background-color: #ffffff;">
        <div class="max-w-5xl mx-auto">
          <p class="text-sm font-semibold tracking-widest uppercase mb-3 text-center" style={`color: ${GOLD_TEXT};`}>
            Diseños disponibles
          </p>
          <h2
            class="text-center text-2xl md:text-3xl font-bold mb-14"
            style="font-family: 'Playfair Display', serif; color: #5A1B5E;"
          >
            Nuestras plantillas
          </h2>

          <style>
            .tcard {
              background: white;
              border-radius: 1rem;
              overflow: hidden;
              border: 1px solid #EDD5E8;
              box-shadow: 0 2px 8px rgba(90,27,94,0.07);
              transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              text-decoration: none;
              display: flex;
              flex-direction: column;
            }
            .tcard:hover {
              transform: translateY(-8px);
              box-shadow: 0 20px 48px rgba(90,27,94,0.18), 0 4px 12px rgba(90,27,94,0.08);
            }
            .tcard-overlay {
              position: absolute; inset: 0;
              background: rgba(30,10,40,0.38);
              opacity: 0;
              transition: opacity 0.3s ease;
              pointer-events: none;
            }
            .tcard:hover .tcard-overlay { opacity: 1; }


            .tcard-btn { transition: background-color 0.22s ease; }
            .tcard:hover .tcard-btn { background-color: #3A1140 !important; }

            .tcard-gradient-border {
              width: 3px;
              border-radius: 3px;
              flex-shrink: 0;
              margin-right: 0.85rem;
              background: linear-gradient(to bottom, #C49B3A, #5A1B5E, #E8B4BC, #7A2E8A, #C49B3A);
              background-size: 100% 300%;
              animation: gradientFlow 2.8s ease infinite alternate;
            }
          </style>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            {CATALOGO.map((t) => (
              <a href="/plantillas" class="tcard">

                <!-- Preview -->
                <div class="relative" style={`height:240px; background:${t.gradiente}; overflow:hidden; flex-shrink:0;`}>
                  {t.esEspacio && (
                    <div aria-hidden="true" style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,0.8) 1px,transparent 1px);background-size:20px 20px;" />
                  )}
                  <div class="tcard-overlay" />

                  <!-- Tag categoría esquina superior derecha -->
                  <span style="position:absolute;top:12px;right:12px;font-size:0.58rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;padding:4px 10px;border-radius:4px;background:rgba(0,0,0,0.55);color:white;backdrop-filter:blur(4px);">
                    {t.categoria}
                  </span>

                </div>

                <!-- Cuerpo con borde izquierdo animado -->
                <div style="display:flex;flex:1;padding:1rem;">
                  <div class="tcard-gradient-border" />
                  <div style="flex:1;display:flex;flex-direction:column;gap:0.45rem;">
                    <p style="font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#3A1140;margin:0;">
                      {t.nombreDisplay}
                    </p>
                    <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.22rem;">
                      {t.features.map((f) => (
                        <li style="display:flex;align-items:center;gap:0.35rem;font-size:0.68rem;color:#555;">
                          <span style="font-size:0.75rem;">{f.emoji}</span>
                          <span>{f.label}</span>
                        </li>
                      ))}
                    </ul>
                    <div style="margin-top:auto;padding-top:0.5rem;border-top:1px solid #F0E0E8;">
                      <p style="font-size:0.55rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#7A5C10;margin-bottom:2px;">Precio</p>
                      <!-- TODO: reemplazar con precio real -->
                      <p style="font-size:0.95rem;font-weight:800;color:#3A1140;margin:0;">
                        ${t.precioDefault.cop.toLocaleString("es-CO")} COP
                      </p>
                    </div>
                  </div>
                </div>

                <!-- Botón Ver plantilla -->
                <div style="padding:0 1rem 1rem;">
                  <div class="tcard-btn" style="width:100%;font-weight:700;font-size:0.875rem;padding:0.7rem 0;border-radius:0.875rem;text-align:center;background-color:#5A1B5E;color:#F8F5F0;letter-spacing:0.01em;">
                    Ver plantilla →
                  </div>
                </div>
              </a>
            ))}
          </div>

          <div class="text-center mt-10">
            <a
              href="/plantillas"
              class="text-sm font-semibold px-8 py-3 rounded-full transition-all inline-block shadow-sm"
              style="background-color: #5A1B5E; color: #F8F5F0;"
            >
              Ver todas y personalizar →
            </a>
          </div>
        </div>
      </section>

      <!-- 5. CÓMO FUNCIONA -->
      <section aria-label="Cómo funciona" class="px-6 py-20" style="background-color: #5A1B5E;">
        <div class="max-w-4xl mx-auto">
          <h2
            class="text-center text-2xl font-bold mb-12"
            style="font-family: 'Playfair Display', serif; color: #F8F5F0;"
          >
            ¿Cómo funciona?
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
            {PASOS.map((p) => (
              <div class="text-center">
                <p class="text-4xl font-bold mb-3" style="color: #C49B3A; font-family: 'Playfair Display', serif;">{p.num}</p>
                <p class="font-semibold text-base mb-2" style="color: #F8F5F0;">{p.titulo}</p>
                <p class="text-sm leading-relaxed" style="color: #E8B4BC;">{p.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- 6. TESTIMONIOS -->
      <TestimoniosSection />

      <!-- 7. FAQ (isla React por la interactividad del acordeón) -->
      <FAQSection client:load />

      <!-- 8. CTA FINAL -->
      <section class="px-6 py-20 text-center max-w-2xl mx-auto">
        <h2
          class="text-2xl md:text-3xl font-bold mb-4"
          style="font-family: 'Playfair Display', serif; color: #5A1B5E;"
        >
          ¿Lista para sorprender a tus invitados?
        </h2>
        <p class="text-sm mb-8" style="color: #4A4A4A;">
          Personaliza tu invitación en minutos y compártela al instante.
        </p>
        <!-- Botón funcional → WhatsApp mientras el formulario automático no esté listo -->
        <a
          href={`https://wa.me/${WHATSAPP_CONTACTO}?text=${WHATSAPP_CTA}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-base font-semibold px-10 py-4 rounded-full shadow-lg transition-all inline-block"
          style="background-color: #5A1B5E; color: #F8F5F0;"
        >
          Crear mi invitación →
        </a>
      </section>

    </main>

    <!-- 9. FOOTER -->
    <footer class="px-6 py-8 border-t text-center text-xs" style="border-color: #E8B4BC; color: #5A5A5A;">
      © 2026 Celebrarte · Invitaciones digitales · Hecho con amor ✨
    </footer>

  </div>
</Base>
